generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  AGENCY_ADMIN
  SEO_MANAGER
  SEO_EXPERT
  CLIENT
}

enum AgencyStatus {
  ACTIVE
  SUSPENDED
}

enum CmsType {
  WORDPRESS
  SHOPIFY
}

enum IntegrationStatus {
  CONNECTED
  BROKEN
  DISCONNECTED
}

enum BlogStatus {
  DRAFT
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  PUBLISHED
  REJECTED
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  phone        String?  @unique
  passwordHash String?
  name         String
  role         Role
  agencyId     String?
  clientId     String?
  isActive     Boolean  @default(true)

  // OAuth fields (null for email/password users)
  provider     String?  // "google" | "facebook" | "microsoft"
  providerId   String?  // ID from the OAuth provider

  // Refresh token stored hashed so we can revoke it
  refreshTokenHash String?

  // OTP for email verification during self-signup
  otpCode    String?
  otpExpires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency      Agency?            @relation(fields: [agencyId], references: [id])
  client      Client?            @relation(fields: [clientId], references: [id])
  assignments ClientAssignment[]
  blogsAuthored Blog[]           @relation("author")
  blogsReviewed Blog[]           @relation("reviewer")
  blogHistory  BlogHistory[]

  @@unique([provider, providerId])
  @@index([agencyId])
  @@index([clientId])
}

model Agency {
  id        String       @id @default(uuid())
  name      String
  status    AgencyStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users        User[]
  clients      Client[]
  inviteTokens InviteToken[]
}

model InviteToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  email     String
  name      String
  role      Role
  agencyId  String
  clientIds String?
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  agency Agency @relation(fields: [agencyId], references: [id])

  @@index([agencyId])
}

model Client {
  id         String   @id @default(uuid())
  agencyId   String
  name       String
  websiteUrl String
  industry   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  agency       Agency             @relation(fields: [agencyId], references: [id])
  integrations Integration[]
  blogs        Blog[]
  users        User[]
  assignments  ClientAssignment[]

  @@index([agencyId])
}

model ClientAssignment {
  id       String @id @default(uuid())
  clientId String
  userId   String

  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([clientId, userId])
  @@index([userId])
}

model Integration {
  id              String            @id @default(uuid())
  clientId        String
  type            CmsType
  siteUrl         String
  username        String?
  tokenEncrypted  String
  status          IntegrationStatus @default(CONNECTED)
  lastTestedAt    DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model Blog {
  id               String     @id @default(uuid())
  clientId         String
  authorId         String
  reviewerId       String?
  title            String
  slug             String
  content          String
  metaTitle        String?
  metaDescription  String?
  featuredImageUrl String?
  status           BlogStatus @default(DRAFT)
  cmsType          CmsType?
  cmsPostId        String?
  livePostUrl      String?
  publishedAt      DateTime?
  reviewerNote     String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  client   Client      @relation(fields: [clientId], references: [id])
  author   User        @relation("author", fields: [authorId], references: [id])
  reviewer User?       @relation("reviewer", fields: [reviewerId], references: [id])
  history  BlogHistory[]

  @@index([clientId])
  @@index([authorId])
  @@index([status])
}

model BlogHistory {
  id        String   @id @default(uuid())
  blogId    String
  actorId   String
  action    String
  note      String?
  createdAt DateTime @default(now())

  blog  Blog @relation(fields: [blogId], references: [id])
  actor User @relation(fields: [actorId], references: [id])

  @@index([blogId])
}
