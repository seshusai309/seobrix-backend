{
  "name": "seo-brix-backend",
  "version": "1.0.0",
  "description": "SEO Brix V1 Backend — blog publishing platform for agencies",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
